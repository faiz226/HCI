OPENROUTER_API_KEY=your_openrouter_api_key_here
APP_URL=http://localhost:3000

# Single-model free preset (avoid @preset/best-free-chatbot — exceeds OpenRouter's 3-model cap)
OPENROUTER_MODEL=@preset/kimi-2-6-free-only

# Optional fallbacks when the primary free model is rate-limited or unavailable
# OPENROUTER_FALLBACK_MODELS=moonshotai/kimi-k2.6:free,meta-llama/llama-3.3-70b-instruct:free

# Optional tuning
# OPENROUTER_MAX_RETRIES=4
# OPENROUTER_RETRY_BASE_MS=1000
# OPENROUTER_RETRY_MAX_MS=30000
# OPENROUTER_REQUEST_TIMEOUT_MS=90000
# OPENROUTER_MAX_TOKENS=768
# OPENROUTER_TEMPERATURE=0.65
